{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/chat",
      "regex": "^/api/chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/chat(?:/)?$"
    },
    {
      "page": "/api/monitor/drift",
      "regex": "^/api/monitor/drift(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/monitor/drift(?:/)?$"
    },
    {
      "page": "/api/monitor/liquidity",
      "regex": "^/api/monitor/liquidity(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/monitor/liquidity(?:/)?$"
    },
    {
      "page": "/api/monitor/reallocation",
      "regex": "^/api/monitor/reallocation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/monitor/reallocation(?:/)?$"
    },
    {
      "page": "/api/monitor/spending",
      "regex": "^/api/monitor/spending(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/monitor/spending(?:/)?$"
    },
    {
      "page": "/api/notifications/checkin",
      "regex": "^/api/notifications/checkin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/notifications/checkin(?:/)?$"
    },
    {
      "page": "/api/plaid/autofill",
      "regex": "^/api/plaid/autofill(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/plaid/autofill(?:/)?$"
    },
    {
      "page": "/api/plaid/create-link-token",
      "regex": "^/api/plaid/create\\-link\\-token(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/plaid/create\\-link\\-token(?:/)?$"
    },
    {
      "page": "/api/plaid/exchange-token",
      "regex": "^/api/plaid/exchange\\-token(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/plaid/exchange\\-token(?:/)?$"
    },
    {
      "page": "/api/plaid/investments",
      "regex": "^/api/plaid/investments(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/plaid/investments(?:/)?$"
    },
    {
